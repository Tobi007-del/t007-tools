{
  "name": "@t007/utils",
  "version": "0.0.32",
  "description": "High-performance utilities for the t007 ecosystem.",
  "author": "Oketade Oluwatobiloba <tobioketade007@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tobi007-del/t007-tools.git",
    "directory": "packages/utils"
  },
  "homepage": "https://github.com/Tobi007-del/t007-tools/blob/main/packages/utils#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./hooks/react": {
      "types": "./dist/hooks/react.d.ts",
      "import": "./dist/hooks/react.js",
      "require": "./dist/hooks/react.cjs",
      "default": "./dist/hooks/react.js"
    },
    "./hooks/vanilla": {
      "types": "./dist/hooks/vanilla.d.ts",
      "import": "./dist/hooks/vanilla.js",
      "require": "./dist/hooks/vanilla.cjs",
      "default": "./dist/hooks/vanilla.js"
    },
    "./components/react": {
      "types": "./dist/components/react.d.ts",
      "import": "./dist/components/react.js",
      "require": "./dist/components/react.cjs",
      "default": "./dist/components/react.js"
    },
    "./styles/ripple.css": "./dist/styles/ripple.css",
    "./styles/scroll-assist.css": "./dist/styles/scroll-assist.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "prepublishOnly": "shx cp ../../LICENSE ."
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t007",
    "ecosystem",
    "vanilla-js",
    "react",
    "utils",
    "helpers",
    "dom-manipulation",
    "shared-logic",
    "performance"
  ],
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild-sass-plugin": "^3.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "sia-reactor": "^0.0.33"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
